meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/users/me
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "firstName": "John",
    "lastName": "Smith",
    "heightCm": "182.00",
    "currentWeightKg": "76.00",
    "goalType": "weight_loss",
    "activityLevel": "moderate"
  }
}
