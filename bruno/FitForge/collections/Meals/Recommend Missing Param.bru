meta {
  name: Recommend Missing Param
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/meals/recommend
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("returns 400 when mealTime is missing", function () {
    expect(res.getStatus()).to.equal(400);
    expect(res.getBody().error).to.match(/mealTime/i);
  });
}
