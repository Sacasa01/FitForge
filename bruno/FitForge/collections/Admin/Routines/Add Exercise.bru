meta {
  name: Add Exercise
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/admin/routines/{{adminRoutineId}}/exercises
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "exerciseId": {{exerciseId}},
    "sets": 4,
    "reps": 8,
    "orderIndex": 0
  }
}

vars:post-response {
  routineExerciseId: res.body.id
}
