meta {
  name: Create Diet
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/admin/diets
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Cut 2000",
    "description": "Moderate deficit",
    "dailyKcal": 2000,
    "goalType": "weight_loss"
  }
}

vars:post-response {
  adminDietId: res.body.id
}
